{
  "manifest_version": 3,
  "name": "ISC2 CPE Helper",
  "version": "0.1.0",
  "description": "Record CISSP CPE credits from Security Now and Risky Business podcasts straight into the ISC2 CPE submission form, using on-device AI.",
  "minimum_chrome_version": "138",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [
    "https://feeds.twit.tv/*",
    "https://risky.biz/*",
    "*://*.isc2.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ISC2 CPE Helper (opens side panel)",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["*://*.isc2.org/*"],
      "js": ["content/autofill.js"]
    }
  ]
}
